APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# First-run installer secret (required by /api/install). Leave empty to disable installs.
INSTALL_SECRET=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Live orders use Laravel Reverb — must be "reverb" (the default "log" sends
# broadcast events to the log file instead of the websocket = no live updates).
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# ── Reverb (realtime / websockets) ──────────────────────────────────────────
REVERB_APP_ID=
# ⚠️ The KEY goes into the browser websocket URL (wss://host/app/<KEY>) and is
# NOT url-encoded by pusher-js. Use only URL-safe characters (letters, numbers,
# dashes) — NO "#", "?", "/", "%", etc., or the browser refuses the connection
# and realtime silently fails. Must match the frontend environment.*.ts key.
REVERB_APP_KEY=
REVERB_APP_SECRET=

# Where the Reverb daemon binds (php artisan reverb:start).
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Where the BACKEND connects to publish events (server-to-server). In production
# behind a reverse proxy, publish to the LOCAL Reverb (127.0.0.1:8080 / http) —
# pointing this at the public https domain loops back to the server and fails.
# Locally: 127.0.0.1 / 8080 / http. The browser uses its own frontend config
# (public host, port 443, wss) — not these values.
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
